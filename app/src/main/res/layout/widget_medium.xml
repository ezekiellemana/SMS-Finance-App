<?xml version="1.0" encoding="utf-8"?>
<!--
  Medium Widget — fully flexible with layout_weight.
  Every section fills proportional space regardless of launcher cell size.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: name + balance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMART MONEY"
                android:textColor="#77AAB4C3"
                android:textSize="7sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tv_balance_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TZS ---"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Right: income + expenses + dot -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="#FF3DDAD7"
                    android:text=""
                    android:textSize="1sp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_income_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ ---"
                    android:textColor="#FF3DDAD7"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_expense_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ ---"
                android:textColor="#FFFF5C5C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/widget_divider"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Recent activity label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="RECENT ACTIVITY"
        android:textColor="#443DDAD7"
        android:textSize="7sp"
        android:letterSpacing="0.1"
        android:gravity="center_vertical" />

    <!-- ── Transaction 1 ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tx1_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tx1_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="↑"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tx1_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="---" />

            <TextView
                android:id="@+id/tx1_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#77AAB4C3"
                android:textSize="8sp"
                android:text="---" />

        </LinearLayout>

        <TextView
            android:id="@+id/tx1_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="---" />

    </LinearLayout>

    <!-- ── Transaction 2 ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tx2_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tx2_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="↑"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tx2_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="---" />

            <TextView
                android:id="@+id/tx2_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#77AAB4C3"
                android:textSize="8sp"
                android:text="---" />

        </LinearLayout>

        <TextView
            android:id="@+id/tx2_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="---" />

    </LinearLayout>

    <!-- ── Transaction 3 ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tx3_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tx3_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="↑"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tx3_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="---" />

            <TextView
                android:id="@+id/tx3_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#77AAB4C3"
                android:textSize="8sp"
                android:text="---" />

        </LinearLayout>

        <TextView
            android:id="@+id/tx3_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="---" />

    </LinearLayout>

</LinearLayout>