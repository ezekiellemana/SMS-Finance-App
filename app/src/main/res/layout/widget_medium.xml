<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E61F2633"
    android:baselineAligned="false"
    android:padding="12dp">

    <!-- Header row: fixed height eliminates nested-weight warning -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_app_name"
                android:textColor="#77AAB4C3"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tv_balance_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_balance_placeholder"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_income_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_income_arrow"
                android:textColor="#FF3DDAD7"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_expense_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_expense_arrow"
                android:textColor="#FFFF5C5C"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp"
        android:text="" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="14dp"
        android:text="@string/widget_recent_activity"
        android:textColor="#443DDAD7"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:gravity="center_vertical" />

    <!-- Transaction row 1: fixed height eliminates nested-weight warning -->
    <LinearLayout
        android:id="@+id/tx1_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:background="#1AFFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tx1_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_tx_arrow"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tx1_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx1_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#77AAB4C3"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx1_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="@string/widget_value_placeholder" />

    </LinearLayout>

    <!-- Transaction row 2 -->
    <LinearLayout
        android:id="@+id/tx2_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:background="#1AFFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tx2_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_tx_arrow"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tx2_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx2_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#77AAB4C3"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx2_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="@string/widget_value_placeholder" />

    </LinearLayout>

    <!-- Transaction row 3 -->
    <LinearLayout
        android:id="@+id/tx3_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:background="#1AFFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tx3_type_icon"
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_tx_arrow"
            android:textColor="#FF3DDAD7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tx3_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx3_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#77AAB4C3"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:text="@string/widget_value_placeholder" />

        <TextView
            android:id="@+id/tx3_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3DDAD7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:text="@string/widget_value_placeholder" />

    </LinearLayout>

</LinearLayout>