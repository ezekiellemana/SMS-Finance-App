<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_green"
    android:baselineAligned="false"
    android:padding="14dp">

    <!-- Top row: dot + app name + time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <TextView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="#FF69F0AE"
            android:layout_marginEnd="6dp"
            android:text="" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_app_name"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_tx1_date"
            android:textColor="#55FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Balance + income/expense pills -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_est_balance"
                android:textColor="#88FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_preview_balance"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Income pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/widget_pill_income"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_income_label"
                android:textColor="#AA69F0AE"
                android:textSize="11sp"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_preview_income"
                android:textColor="#FF69F0AE"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Expense pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/widget_pill_expense"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_expense_label"
                android:textColor="#AAFF5C5C"
                android:textSize="11sp"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_preview_expense"
                android:textColor="#FFFF5C5C"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/widget_divider"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:text="" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_recent_activity"
        android:textColor="#443DDAD7"
        android:textSize="11sp"
        android:letterSpacing="0.14"
        android:textAllCaps="true"
        android:layout_marginBottom="5dp" />

    <!-- Transaction row 1 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/prev_tx1_icon"
            android:layout_width="14dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx1_icon"
            android:textColor="#FF69F0AE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/prev_tx1_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx1_amount"
            android:textColor="#FF69F0AE"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prev_tx1_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/prev_tx1_amount"
            android:layout_centerVertical="true"
            android:layout_marginEnd="6dp"
            android:text="@string/widget_preview_tx1_date"
            android:textColor="#55FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/prev_tx1_icon"
            android:layout_toStartOf="@id/prev_tx1_date"
            android:layout_centerVertical="true"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="4dp"
            android:text="@string/widget_preview_tx1_source"
            android:textColor="#EEFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

    </RelativeLayout>

    <!-- Transaction row 2 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/prev_tx2_icon"
            android:layout_width="14dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx2_icon"
            android:textColor="#FFFF5C5C"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/prev_tx2_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx2_amount"
            android:textColor="#FFFF5C5C"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prev_tx2_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/prev_tx2_amount"
            android:layout_centerVertical="true"
            android:layout_marginEnd="6dp"
            android:text="@string/widget_preview_tx2_date"
            android:textColor="#55FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/prev_tx2_icon"
            android:layout_toStartOf="@id/prev_tx2_date"
            android:layout_centerVertical="true"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="4dp"
            android:text="@string/widget_preview_tx2_source"
            android:textColor="#EEFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

    </RelativeLayout>

    <!-- Transaction row 3 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/widget_row_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/prev_tx3_icon"
            android:layout_width="14dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx3_icon"
            android:textColor="#FF69F0AE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/prev_tx3_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_preview_tx3_amount"
            android:textColor="#FF69F0AE"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prev_tx3_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/prev_tx3_amount"
            android:layout_centerVertical="true"
            android:layout_marginEnd="6dp"
            android:text="@string/widget_preview_tx3_date"
            android:textColor="#55FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/prev_tx3_icon"
            android:layout_toStartOf="@id/prev_tx3_date"
            android:layout_centerVertical="true"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="4dp"
            android:text="@string/widget_preview_tx3_source"
            android:textColor="#EEFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

    </RelativeLayout>

</LinearLayout>