<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main app theme — no action bar, no title bar -->
    <style name="Theme.SMSFinanceWidget" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <!-- Edge-to-edge: transparent bars so Compose controls the drawing -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Static system splash suppressed — video splash handles everything -->
    <style name="Theme.SMSFinanceWidget.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.SMSFinanceWidget</item>
    </style>
    <!-- Video splash theme: full screen, no system splash icon, no action bar -->
    <style name="Theme.SMSFinanceWidget.VideoSplash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.SMSFinanceWidget</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

</resources>